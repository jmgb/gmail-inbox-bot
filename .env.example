# Gmail OAuth2 (Desktop app, External + In production)
# Proyecto GCP: crear uno en console.cloud.google.com con Gmail API + Google Calendar API habilitadas
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Refresh tokens por cuenta (uno por cada cuenta Gmail conectada)
# Obtener con: uv run python scripts/get_refresh_token.py
# Cada config/*.yml referencia su token vía refresh_token_env
GOOGLE_REFRESH_TOKEN_CUENTA1=
GOOGLE_REFRESH_TOKEN_CUENTA2=

# LLM — clasificación y respuestas dinámicas
# Por defecto el clasificador usa gpt-oss-120b vía Groq, con fallback a OpenAI.
OPENAI_API_KEY=
GROQ_API_KEY=

# Telegram (opcional) — avisos de email importante, trades IB y fallos de recordatorios
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Métricas (opcional) — tabla email_metrics en Supabase
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Panel de administración — password del visor de logs (/admin/logs)
LOGS_VIEWER_PASSWORD=

# Observability (opcional)
SENTRY_DSN=

# Runtime
LOG_LEVEL=INFO
ENVIRONMENT=development

# Flags de los background threads (opcional)
# DISABLE_BOT=1   # solo admin UI (sin polling ni scheduler de recordatorios)
# DRY_RUN=1       # los threads operan en seco (no envían, no guardan estado)
