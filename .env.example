# Gmail account used by the bot
GMAIL_ADDRESS=

# Optional alias configured in Gmail "Send as"
GMAIL_SEND_AS=

# Gmail search query for polling
GMAIL_QUERY=is:unread in:inbox

# Google OAuth2 (Desktop app, External + In production)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# OpenAI
OPENAI_API_KEY=

# Optional observability
SENTRY_DSN=

# Runtime
LOG_LEVEL=INFO
PORT=3006
ENVIRONMENT=development
